# Supabase — copy to `.env.local` and fill in from your project's
# Settings → API page. Both are safe to expose to the browser (the anon key
# is gated by row-level security).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Auth is optional: with these unset the site runs exactly as before and
# progress stays in localStorage only (no sign-in button is shown).

# --- Admin dashboard (optional, server-only) ---
# Comma-separated admin emails. The /admin pages are visible only to a signed-in
# user whose email is in this list; everyone else gets a 404.
ADMIN_EMAILS=you@example.com
# Supabase SECRET key (sb_secret_...) — lets the admin dashboard read analytics
# across ALL users (bypasses row-level security). MUST stay server-side; never
# prefix with NEXT_PUBLIC. Find it in Supabase → Settings → API Keys.
SUPABASE_SECRET_KEY=your-supabase-secret-key
